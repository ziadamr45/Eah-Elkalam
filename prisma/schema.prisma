generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Trend {
  id          String   @id @default(cuid())
  headline    String
  explanation String
  platform    String   // youtube, facebook, tiktok, x, google
  category    String   // sports, tech, entertainment, politics, food, education
  heatScore   Int      // 1-10
  sentiment   String   // positive, negative, neutral, viral
  region      String?  // egypt governorate
  videoUrl    String?  // for youtube/tiktok embeds
  postUrl     String?  // for facebook/x links
  imageUrl    String?
  comments    String?  // JSON array of comment strings
  aiSummary   String?
  sourceId    String?  // external ID from the source platform
  fetchedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Match {
  id          String   @id @default(cuid())
  homeTeam    String
  awayTeam    String
  homeScore   Int      @default(0)
  awayScore   Int      @default(0)
  status      String   @default("upcoming") // live, finished, upcoming
  league      String
  matchDate   DateTime
  aiAnalysis  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CrawlLog {
  id        String   @id @default(cuid())
  message   String
  source    String
  status    String   // success, error, pending
  createdAt DateTime @default(now())
}
