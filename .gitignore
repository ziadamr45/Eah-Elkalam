# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example in repo)
.env
.env.local
.env.*.local
mini-services/**/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt
server.log

# ========= Platform-specific / not needed for Vercel =========
# Skills directory (SDK tools, not part of the app)
/skills/

# Internal scripts & configs
/.zscripts/

# Agent context files
/agent-ctx/

# Download folder
/download/

# Example code
/examples/

# Database files (Vercel uses serverless, no local DB)
/db/*.db
/db/*.db-journal

# Caddy gateway config (only for local dev)
Caddyfile

# Worklog (dev notes)
worklog.md



# Mini services are backend-only, not deployable on Vercel
/mini-services/

# Prisma DB file
prisma/*.db
prisma/*.db-journal
